# Environment variables for TTS engines

# Coqui TTS model to use. A list of available models can be found at:
# https://github.com/coqui-ai/TTS/blob/dev/TTS/.models.json
# Defaults to "tts_models/en/ljspeech/vits" if not set.
# COQUI_MODEL_NAME=

# Full path to the Piper voice model (.onnx file).
# Models can be downloaded from: https://huggingface.co/rhasspy/piper-voices
# PIPER_VOICE_PATH=
